# Urban Environmental Intelligence API — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All variables are loaded by pydantic-settings (app/core/config.py).
# Required variables have no default — the app will fail to start
# if they are missing.

# --- Database ---
# PostgreSQL connection string for the async engine (asyncpg driver).
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/urban_env

# --- API Security ---
# API key required in the X-Api-Key header for all /api/v1/ endpoints.
# In production, use a strong random string (e.g. openssl rand -hex 32).
API_KEY=dev-api-key-change-me

# --- AI Integration ---
# Anthropic API key for Claude-powered environmental insights.
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Ingestion ---
# How often (in minutes) the background scheduler fetches new data
# from OpenAQ and Open-Meteo APIs.
INGESTION_INTERVAL_MINUTES=60

# --- OpenAQ ---
# API key for OpenAQ v3 (optional but recommended to avoid rate limits).
# Register at: https://explore.openaq.org/register
OPENAQ_API_KEY=

# --- Cache ---
# Time-to-live in seconds for cached AI insights.
# Should align with INGESTION_INTERVAL_MINUTES (3600s = 60min).
CACHE_TTL_SECONDS=3600

# --- AI Model ---
# Maximum tokens for AI insight generation.
AI_MAX_TOKENS=1024

# --- Server ---
# Uvicorn host and port (used when running directly with `python main.py`).
HOST=0.0.0.0
PORT=8000
DEBUG=false
