# =============================================================================
# Urban Environmental Intelligence API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# All variables are loaded by docker-compose.yml and passed to containers.
# =============================================================================

# --- PostgreSQL ---
# These are used by BOTH the postgres container (to create the DB)
# and the api container (to connect to it).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD
POSTGRES_DB=urban_env_db

# --- API Security ---
# API key required in the X-Api-Key header for all /api/v1/ endpoints.
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=CHANGE_ME_GENERATE_A_RANDOM_KEY

# --- AI Integration ---
# Anthropic API key for Claude-powered environmental insights.
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- OpenAQ ---
# API key for OpenAQ v3 (optional but recommended to avoid rate limits).
# Register at: https://explore.openaq.org/register
OPENAQ_API_KEY=

# --- Ingestion ---
# How often (in minutes) the background scheduler fetches new data
# from OpenAQ and Open-Meteo APIs. Lower values = fresher data but
# higher API rate limit consumption. Default: 60.
INGESTION_INTERVAL_MINUTES=60

# --- Rate Limiting ---
# Maximum API requests per minute per client IP.
# Default: 60 (1 request/second sustained).
RATE_LIMIT_PER_MINUTE=60

# --- Cache ---
# Time-to-live (seconds) for cached AI insights.
# Should align with INGESTION_INTERVAL_MINUTES (3600s = 60min).
CACHE_TTL_SECONDS=3600

# --- CORS ---
# Comma-separated list of allowed origins for cross-origin requests.
# In production, restrict to your actual frontend domain(s).
CORS_ORIGINS=http://localhost:3000
